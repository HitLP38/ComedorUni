# ============================================
# Base de Datos PostgreSQL
# ============================================
DATABASE_URL="postgresql://comedoruni_user:comedoruni_password@postgres:5432/comedoruni"
POSTGRES_USER=comedoruni_user
POSTGRES_PASSWORD=comedoruni_password
POSTGRES_DB=comedoruni

# ============================================
# Cache y Cola Virtual (Redis)
# ============================================
REDIS_URL="redis://redis:6379"

# ============================================
# Autenticación y Seguridad
# ============================================
JWT_SECRET="tu-clave-jwt-secreta-de-min-32-caracteres-aleatorios-aqui"
NODE_ENV=development

# ============================================
# reCAPTCHA v3 (Google)
# ============================================
GOOGLE_RECAPTCHA_SECRET="clave-secreta-recaptcha-aqui"
GOOGLE_RECAPTCHA_PUBLIC="clave-publica-recaptcha-aqui"

# ============================================
# SMTP para envío de correos (OTP, notificaciones)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu-email@gmail.com"
SMTP_PASSWORD="tu-contraseña-app-gmail"
SMTP_FROM="noreply@comedoruni.uni.pe"

# ============================================
# API Backend
# ============================================
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN="http://localhost:5173"

# ============================================
# Frontend React+Vite
# ============================================
VITE_API_URL="http://localhost:3001"
